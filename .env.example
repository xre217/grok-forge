# Grok Forge — Local-first public defaults
# Copy to .env.local:  cp .env.example .env.local

# ── Runtime mode ─────────────────────────────────────────────
# local = Ollama only | hybrid = try xAI then Ollama | cloud = xAI only
FORGE_MODE=local
FORGE_LOCAL_FIRST=1

# ── Persona (public defaults — customize freely) ─────────────
FORGE_USER_NAME=you
# FORGE_PERSONA=Your custom co-pilot personality.
# FORGE_PROJECT=My AI Studio

# ── Optional VILO pack (advanced sovereignty features) ───────
# Enables VILO skill + stronger ledger injection in system prompt.
# Set the same value for both vars when using the pack.
# FORGE_PACK=vilo
# NEXT_PUBLIC_FORGE_PACK=vilo

# ── Ollama (local reasoner) ──────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=llama3.2:3b

# ── Optional memory ledger ───────────────────────────────────
# Writes to $JARVIS_HOME/memory/ledger.jsonl when enabled.
FORGE_LEDGER_ENABLED=1
JARVIS_HOME=~/.jarvis

# ── Optional THRML Ising engine (advanced) ───────────────────
# Leave unset to use hash fallback (works out of the box).
# THRML_REPO_PATH=/path/to/thrml/checkout
# THRML_PYTHON=python3

# ── Session backups (server-side, on export) ─────────────────
# FORGE_HOME=~/.forge

# ── Local server ─────────────────────────────────────────────
FORGE_PORT=3847

# ── Links (optional) ─────────────────────────────────────────
# FORGE_GITHUB_URL=https://github.com/your-org/grok-forge
# NEXT_PUBLIC_FORGE_GITHUB_URL=https://github.com/your-org/grok-forge

# ── Optional cloud layer (not required) ──────────────────────
# XAI_API_KEY=
# XAI_MODEL=grok-4.3