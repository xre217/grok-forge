# Grok Forge — Local-first (no xAI credits, no Vercel required)

# Primary mode: local = Ollama only | hybrid = try xAI then Ollama | cloud = xAI only
FORGE_MODE=local
FORGE_LOCAL_FIRST=1

# Ollama (local reasoner)
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=llama3.2:3b

# VILO Evidence Ledger
JARVIS_HOME=~/.jarvis

# Local server port (forge:local script)
FORGE_PORT=3847

# Optional cloud layer (not required for local build)
# XAI_API_KEY=
# XAI_MODEL=grok-4.3