# Grok Forge — environment template
# Copy to .env.local and fill in values

# xAI / Grok API (required for live chat)
XAI_API_KEY=
XAI_MODEL=grok-4.3

# Ollama fallback (optional)
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=llama3.2:3b

# Custom domain target
FORGE_DOMAIN=forge.trefong.com